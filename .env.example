# Qwen API Key (recommended - for server-side LLM integration)
# Get your key from https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_api_key_here

# Gemini API Key (fallback - for server-side LLM integration)
# Get your key from https://ai.google.dev/gemini-api
GEMINI_API_KEY=your_gemini_api_key_here

# You can also set these in your deployment environment