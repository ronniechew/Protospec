    "autoprefixer": "^10.4.27",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "nuxt": "^4.4.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3",
    "vue": "^3.5.32"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.102.1",
    "pdfmake": "^0.3.7"
